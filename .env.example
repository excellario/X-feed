# x-feed-mcp configuration. NEVER commit your real .env.

# --- X (Twitter) session ---------------------------------------------------

# Required: rettiwt-api API key = base64 of a logged-in account's cookies.
# Generate it WITHOUT a password:
#   1. Log into your DEDICATED (throwaway) X account in a browser.
#   2. Open DevTools > Application > Cookies, copy auth_token, ct0, twid.
#   3. In the browser console, run:
#        btoa("auth_token=<AUTH_TOKEN>;ct0=<CT0>;twid=<TWID>;")
#   4. Paste the output here. It grants full access to that account, keep it secret.
X_API_KEY=your-base64-cookie-api-key

# Optional: default set of handles to track (comma or space separated, @ optional).
# X_HANDLES=@sama, @OpenAI, @AnthropicAI, @GoogleDeepMind, @karpathy

# --- Transport (local stdio vs remote HTTP) --------------------------------

# "stdio" (default) or "http" (remote deploy).
# MCP_TRANSPORT=stdio

# Required ONLY when MCP_TRANSPORT=http. Long random secret; callers send it as
# `Authorization: Bearer <value>` or in the path as /mcp/<value>.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MCP_AUTH_TOKEN=replace-with-a-long-random-secret

# Optional: HTTP port. Hosts like Render set PORT automatically.
# PORT=3000

# Optional: self-ping keepalive (auto-enabled on Render via RENDER_EXTERNAL_URL).
# KEEPALIVE_URL=https://your-app.onrender.com
# KEEPALIVE_MINUTES=10
